# ─────────────────────────────────────────────────────────────
#  .env.example — Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────
DB_URL=postgresql+asyncpg://judicial:judicial@localhost:5432/judicial_db
DB_SYNC_URL=postgresql+psycopg2://judicial:judicial@localhost:5432/judicial_db

# ── Paths ─────────────────────────────────────────────────────
RAW_PDF_DIR=data/raw
PROCESSED_DIR=data/processed
FAISS_INDEX_DIR=data/faiss_index
CHECKPOINT_DB=data/checkpoint.db

# ── Embedding ─────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DIM=384

# ── Chunking ──────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Pipeline ──────────────────────────────────────────────────
MAX_WORKERS=4
# Set True for production scale (>10K docs) — uses IVF index
USE_IVF=false
FAISS_NLIST=256

# ── FastAPI ───────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
